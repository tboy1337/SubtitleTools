# SubtitleTools — cross-platform Python project (LF source; CRLF for Windows scripts)

* text=auto

# -----------------------------------------------------------------------------
# Source and project configuration (LF)
# -----------------------------------------------------------------------------
*.py            text eol=lf
*.pyi           text eol=lf
*.typed         text eol=lf
*.toml          text eol=lf
*.ini           text eol=lf
*.cfg           text eol=lf
pylintrc        text eol=lf
.coveragerc     text eol=lf
*.spec          text eol=lf
requirements*.txt text eol=lf

# -----------------------------------------------------------------------------
# Documentation and metadata (LF)
# -----------------------------------------------------------------------------
*.md            text eol=lf
LICENSE*        text eol=lf
*.json          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.xml           text eol=lf

# -----------------------------------------------------------------------------
# Subtitle and caption formats (LF — common interchange convention)
# -----------------------------------------------------------------------------
*.srt           text eol=lf
*.vtt           text eol=lf
*.ass           text eol=lf
*.ssa           text eol=lf
*.sbv           text eol=lf
*.ttml          text eol=lf
*.smi           text eol=lf
*.sub           text eol=lf

# -----------------------------------------------------------------------------
# Shell and container tooling (LF)
# -----------------------------------------------------------------------------
*.sh            text eol=lf
Dockerfile*     text eol=lf
Makefile        text eol=lf

# -----------------------------------------------------------------------------
# Windows scripts (CRLF)
# -----------------------------------------------------------------------------
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# -----------------------------------------------------------------------------
# Git metadata (LF)
# -----------------------------------------------------------------------------
.gitattributes  text eol=lf
.gitignore      text eol=lf

# -----------------------------------------------------------------------------
# Binary assets
# -----------------------------------------------------------------------------
# Native / build outputs
*.exe           binary
*.dll           binary
*.so            binary
*.dylib         binary
*.pyd           binary
*.whl           binary

# Images
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.bmp           binary
*.ico           binary
*.webp          binary
*.svg           binary

# Archives
*.zip           binary
*.7z            binary
*.tar           binary
*.gz            binary

# Video and audio (transcription inputs / test media)
*.mp4           binary
*.mkv           binary
*.avi           binary
*.mov           binary
*.webm          binary
*.wmv           binary
*.flv           binary
*.m4v           binary
*.mp3           binary
*.wav           binary
*.flac          binary
*.ogg           binary
*.m4a           binary
*.aac           binary

# Fonts and documents
*.ttf           binary
*.otf           binary
*.pdf           binary

# -----------------------------------------------------------------------------
# GitHub linguist (language statistics)
# -----------------------------------------------------------------------------
tests/test_data/**          linguist-detectable=false
htmlcov/**                  linguist-generated=true
*.egg-info/**               linguist-generated=true
